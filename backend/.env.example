# Application
APP_NAME="RAG PDF API"
DEBUG=false

# CORS — space-separated list wrapped in JSON array syntax
CORS_ORIGINS=["http://localhost:5173"]

# LLM provider: "nvidia" (default) or "ollama"
LLM_PROVIDER=nvidia

# NVIDIA NIM — get key from https://build.nvidia.com (free tier available)
# WARNING: never commit the real key, never prefix with VITE_
NVIDIA_API_KEY=
# Verify the exact model ID on https://build.nvidia.com/models — catalog changes over time
NVIDIA_CHAT_MODEL=

# Ollama (local fallback — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=qwen2.5

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_pdf

# Storage paths (relative to backend/)
UPLOAD_DIR=storage/uploads
STATIC_DIR=storage/static
