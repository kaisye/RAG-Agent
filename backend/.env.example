# LLM Provider
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-...
NVIDIA_CHAT_MODEL=
NVIDIA_EMBED_MODEL=
NVIDIA_RERANK_MODEL=nvidia/llama-3_2-nv-rerankqa-1b-v2
OLLAMA_CHAT_MODEL=qwen2.5
OLLAMA_BASE_URL=http://localhost:11434/v1

# Chunking
CHUNKING_STRATEGY=recursive
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
SEMANTIC_THRESHOLD=0.5
MIN_CHUNK_SIZE=600
MAX_CHUNK_SIZE=1024

# HNSW
HNSW_M=16
HNSW_EF_CONSTRUCT=100
HNSW_EF_SEARCH=128

# Retrieval
RETRIEVAL_STRATEGY=vector
TOP_K_RETRIEVAL=10
RRF_K=60

# Query Transform
QUERY_TRANSFORM=none

# Reranking
RERANK_STRATEGY=none
TOP_K_FINAL=3
RETRIEVE_K=10
MMR_LAMBDA=0.5

# Evaluation
TESTSET_SIZE=50
EVAL_MAX_WORKERS=4
EVAL_TIMEOUT=180

# Storage
DATABASE_URL=sqlite:///./storage/rag.db
CHROMA_PERSIST_DIR=./storage/chroma
UPLOAD_DIR=./storage/uploads
IMAGES_DIR=./storage/images
MARKDOWN_DIR=./storage/markdown
