# Copy this file to .env and fill in your values.
# NEVER commit .env to git. NEVER prefix secrets with VITE_.

# LLM Provider: "nvidia" (default) or "ollama"
LLM_PROVIDER=nvidia

# NVIDIA NIM (https://build.nvidia.com)
NVIDIA_API_KEY=nvapi-...
NVIDIA_CHAT_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# Ollama (local — used when LLM_PROVIDER=ollama)
OLLAMA_CHAT_MODEL=qwen2.5
OLLAMA_BASE_URL=http://localhost:11434/v1

# Qdrant (default: Docker on localhost)
QDRANT_URL=http://localhost:6333

# Retrieval toggles
HYBRID_SEARCH_ENABLED=true
RERANKER_ENABLED=true
HYDE_ENABLED=false
QUERY_DECOMPOSITION_ENABLED=false

# Vision (set true only when using a vision-capable chat model)
CHAT_SUPPORTS_VISION=false
