# Application
APP_NAME="RAG PDF API"
DEBUG=false

# CORS — space-separated list wrapped in JSON array syntax
CORS_ORIGINS=["http://localhost:5173"]

# LLM provider: "ollama" or "nvidia"
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
NVIDIA_API_KEY=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_pdf

# Storage paths (relative to backend/)
UPLOAD_DIR=storage/uploads
STATIC_DIR=storage/static
